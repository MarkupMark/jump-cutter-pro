{
  "name": "jump-cutter",
  "author": {
    "name": "WofWca",
    "email": "wofwca@protonmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WofWca/jumpcutter.git"
  },
  "bugs": {
    "url": "https://github.com/WofWca/jumpcutter/issues"
  },
  "homepage": "https://github.com/WofWca/jumpcutter#readme",
  "scripts": {
    "_abstract-build": "npm run lint && NODE_ENV=production webpack --mode=production",
    "build:gecko": "npm run _abstract-build -- --env browser=gecko --env noreport",
    "build:chromium": "npm run _abstract-build -- --env browser=chromium --env noreport",
    "_abstract-build-and-package": "npm run build:$BROWSER -- --env noreport && cd dist-$BROWSER && rm -f ../dist-$BROWSER.zip && zip -r ../dist-$BROWSER.zip .",
    "build-and-package:gecko": "BROWSER=gecko npm run _abstract-build-and-package",
    "build-and-package:chromium": "BROWSER=chromium npm run _abstract-build-and-package",
    "build-and-package:all": "rm -f dist-*.zip && npm run build-and-package:gecko & npm run build-and-package:chromium",
    "_abstract-serve": "webpack --mode=development --watch",
    "serve:gecko": "npm run _abstract-serve -- --env browser=gecko",
    "serve:chromium": "npm run _abstract-serve -- --env browser=chromium",
    "lint": "eslint ./src/",
    "diagnostics:chromium": "npm run build:chromium && node tools/diagnostics/run-chromium-diagnostics.mjs",
    "diagnostics:local-file": "npm run build:chromium && node tools/diagnostics/run-local-file-diagnostics.mjs",
    "diagnostics:webaudio-demo": "node tools/diagnostics/webaudio-bypass-demo.mjs"
  },
  "sideEffects": [
    "./src/{content,popup,background,options,local-file-player}/main.ts",
    "./src/content/SilenceDetector/SilenceDetectorProcessor.ts",
    "./src/content/VolumeFilter/VolumeFilterProcessor.ts"
  ],
  "dependencies": {
    "@wofwca/smoothie": "^1.36.2-rc0",
    "hh-mm-ss": "^1.2.0",
    "lodash": "^4.17.21",
    "tippy.js": "^6.3.7",
    "tone": "~14.7.77"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.18",
    "@types/firefox-webext-browser": "^120.0.5",
    "@types/hh-mm-ss": "^1.2.3",
    "@types/lodash": "^4.17.20",
    "@types/node": "^24.6.2",
    "@typescript-eslint/eslint-plugin": "^7.9.0",
    "@typescript-eslint/parser": "^7.9.0",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.1",
    "eslint": "^8.44.0",
    "minimize-webext-i18n-json": "^2.0.2",
    "puppeteer-core": "^24.38.0",
    "style-loader": "^4.0.0",
    "svelte": "~4.2.17",
    "svelte-check": "^3.7.1",
    "svelte-loader": "^3.2.0",
    "svelte-preprocess": "^5.1.4",
    "ts-loader": "^9.5.1",
    "typescript": "~5.8.3",
    "webpack": "^5.91.0",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^6.0.1"
  }
}
